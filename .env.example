# Copy to .env.local for local dev, and set these in Vercel → Settings →
# Environment Variables for production.

# Required. Create a key at https://resend.com/api-keys
RESEND_API_KEY=

# Optional. The verified "from" address. Defaults to
# "SOMA Startup <noreply@somastartup.com>" (somastartup.com is verified in
# Resend). Override only if you want a different verified sender.
RESEND_FROM="SOMA Startup <noreply@somastartup.com>"

# Where sign-ups are delivered. Defaults to hello@somastartup.com if unset.
# NOTE: this must be a real, receiving inbox — Resend only sends mail.
CONTACT_EMAIL=hello@somastartup.com

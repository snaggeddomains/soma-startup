# Copy to .env.local for local dev, and set these in Vercel → Settings →
# Environment Variables for production.

# Required. Create a key at https://resend.com/api-keys
RESEND_API_KEY=

# The "from" address. Until somastartup.com is verified in Resend, the code
# falls back to onboarding@resend.dev (which only delivers to the Resend
# account owner). For production, verify the domain in Resend and set this to
# a verified address, e.g. "SOMA Startup <hello@somastartup.com>".
RESEND_FROM="SOMA Startup <hello@somastartup.com>"

# Where sign-ups are delivered. Defaults to hello@somastartup.com if unset.
CONTACT_EMAIL=hello@somastartup.com
